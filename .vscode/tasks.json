{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile-extension",
            "type": "shell",
            "command": "rtk npm run compile",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$tsc"
            ]
        }
    ]
}
