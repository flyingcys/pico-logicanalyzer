      "id": "i2c.write-byte.normal",
      "protocol": "i2c",
      "category": "normal",
      "sampleRate": 1000000,
      "input": {
        "kind": "i2c-operations",
        "operations": [
          { "type": "start" },
          { "type": "byte", "value": 160 },
          { "type": "ack" },
          { "type": "byte", "value": 18 },
          { "type": "ack" },
          { "type": "stop" }
