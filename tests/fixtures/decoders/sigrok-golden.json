      },
      "options": [{ "optionIndex": 0, "value": "shifted" }],
      "expected": [
        { "annotationType": 0, "values": ["Start", "S"] },
        { "annotationType": 7, "rawData": 80, "values": ["Address write: 50", "AW: 50", "50"] },
        { "annotationType": 3, "values": ["ACK", "A"] },
        { "annotationType": 9, "rawData": 18, "values": ["Data write: 12", "DW: 12", "12"] },
        { "annotationType": 3, "values": ["ACK", "A"] },
        { "annotationType": 2, "values": ["Stop", "P"] }
      ]
    },
