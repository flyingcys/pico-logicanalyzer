{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "alwaysStrict": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "suppressImplicitAnyIndexErrors": false,
    "isolatedModules": false,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "include": [
    "src/models/AnalyzerTypes.ts",
    "src/decoders/types.ts",
    "src/models/*.ts",
    "src/decoders/*.ts",
    "src/drivers/types/AnalyzerTypes.ts",
    "src/drivers/AnalyzerDriverBase.ts",
    "src/drivers/VersionValidator.ts",
    "src/services/SignalDescriptionLanguage.ts",
    "src/frontend/core/protocol/bootstrap.ts",
    "src/frontend/core/protocol/window.ts",
    "src/frontend/core/services/exportRequestService.ts",
    "src/frontend/core/stores/decoderMappingHelpers.ts",
    "src/frontend/core/stores/sessionStore.ts",
    "src/frontend/core/stores/waveformStore.ts",
    "src/frontend/core/stores/uiStore.ts",
    "src/extension.ts"
  ],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "coverage",
    ".vscode-test"
  ]
}
